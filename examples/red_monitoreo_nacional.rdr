// ============================================================
entero o_temp;
entero o_viento;
entero o_humedad;
entero o_presion;
cadena o_nombre;
booleano o_alerta;
cadena o_mensaje;

o_temp = 10;
o_temp = o_temp - 2;
o_viento = 68;
o_humedad = 55;
o_presion = 940;
o_nombre = "CORDILLERA";
o_alerta = falso;
o_mensaje = " ";

si o_viento > UMBRAL_VIENTO entonces
    o_alerta = verdadero;
    o_mensaje = "VIENTO FUERTE EN " + o_nombre;
    alerta(o_mensaje);
