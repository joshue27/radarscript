// ============================================================
// REPORTE FINAL RESUMEN
// ============================================================
reporte("========================================");
reporte("RESUMEN NACIONAL DE MONITOREO CLIMATICO");
reporte("========================================");
reporte("Estaciones procesadas: " + estaciones_procesadas);
reporte("Total de alertas: " + total_alertas);

mientras CONTADOR < CICLOS hacer
    reporte("Ciclo de procesamiento Nro: " + CONTADOR);
    CONTADOR = CONTADOR + 1;
fin

reporte("Resumen global del sistema");

si hay_emergencia == verdadero entonces
    reporte("ESTADO NACIONAL: EMERGENCIA CLIMATICA ACTIVA");
    reporte("Se recomienda activar protocolos de contingencia");
    reporte("Central de monitoreo en alerta permanente");
fin

reporte("Fin del reporte nacional");
reporte("Sistema de monitoreo finalizado");
