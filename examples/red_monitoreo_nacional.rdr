e_temp = 33;
e_viento = 40;
e_humedad = 88;
e_presion = 1008;
e_nombre = "LITORAL";
e_alerta = falso;
e_mensaje = " ";

si e_humedad > UMBRAL_HUMEDAD entonces
    e_alerta = verdadero;
    e_mensaje = "HUMEDAD ALTA EN " + e_nombre;
    alerta(e_mensaje);
    total_alertas = total_alertas + 1;
fin

si e_temp > UMBRAL_TEMP_ALTA entonces
