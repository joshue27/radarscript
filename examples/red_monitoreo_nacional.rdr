    s_mensaje = "VIENTO FUERTE EN " + s_nombre;
    alerta(s_mensaje);
    total_alertas = total_alertas + 1;
fin

si s_humedad > UMBRAL_HUMEDAD entonces
    s_alerta = verdadero;
    reporte("HUMEDAD EXTREMA: " + s_nombre);
fin

si s_alerta == verdadero entonces
    hay_emergencia = verdadero;
    reporte("ALERTA ACTIVA: " + s_nombre);
fin

