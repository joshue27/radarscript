programa red_monitoreo_nacional;

// ============================================================
// RED NACIONAL DE MONITOREO CLIMATICO
// Simulacion de 12 estaciones meteorologicas con alertas
// ============================================================

// ---- CONSTANTES DE CONFIGURACION ----
entero UMBRAL_TEMP_ALTA;
entero UMBRAL_TEMP_BAJA;
entero UMBRAL_VIENTO;
entero UMBRAL_HUMEDAD;
entero CICLOS;
entero CONTADOR;

UMBRAL_TEMP_ALTA = 35;
UMBRAL_TEMP_BAJA = 5;
UMBRAL_VIENTO = 60;
UMBRAL_HUMEDAD = 90;
CICLOS = 3;
CONTADOR = 1;

// ---- VARIABLES GLOBALES ----
entero total_alertas;
entero total_reportes;
entero estaciones_procesadas;
cadena resumen_global;
booleano hay_emergencia;

total_alertas = 0;
total_reportes = 0;
estaciones_procesadas = 0;
resumen_global = "INICIO";
hay_emergencia = falso;

// ============================================================
// ESTACION NORTE - COSTA
// ============================================================
entero n_temp;
entero n_viento;
entero n_humedad;
entero n_presion;
cadena n_nombre;
booleano n_alerta;
cadena n_mensaje;

n_temp = 38;
n_viento = 72;
n_humedad = 65;
n_presion = 1013;
n_nombre = "COSTA_NORTE";
n_alerta = falso;
n_mensaje = " ";

si n_temp > UMBRAL_TEMP_ALTA entonces
    n_alerta = verdadero;
    n_mensaje = "TEMPERATURA ALTA EN " + n_nombre;
    alerta(n_mensaje);
    total_alertas = total_alertas + 1;
fin

si n_viento > UMBRAL_VIENTO entonces
    n_alerta = verdadero;
    n_mensaje = "VIENTO FUERTE EN " + n_nombre;
    alerta(n_mensaje);
    total_alertas = total_alertas + 1;
fin

si n_alerta == verdadero entonces
    hay_emergencia = verdadero;
    reporte("ALERTA ACTIVA: " + n_nombre);
fin

estaciones_procesadas = estaciones_procesadas + 1;

// ============================================================
// ESTACION NORTE - SIERRA
// ============================================================
entero s_temp;
entero s_viento;
entero s_humedad;
entero s_presion;
cadena s_nombre;
booleano s_alerta;
cadena s_mensaje;

s_temp = 22;
s_viento = 45;
s_humedad = 80;
s_presion = 1020;
s_nombre = "SIERRA_NORTE";
s_alerta = falso;
s_mensaje = " ";

