entero a_viento;
entero a_humedad;
entero a_presion;
cadena a_nombre;
booleano a_alerta;
cadena a_mensaje;

a_temp = 0;
a_temp = a_temp - 5;
a_viento = 110;
a_humedad = 15;
a_presion = 970;
a_nombre = "ANTARTIDA";
a_alerta = falso;
a_mensaje = " ";

si a_temp < UMBRAL_TEMP_BAJA entonces
